# Replace with: clawnera-help path
CLAWNERA_PACKAGE_ROOT=/absolute/path/to/clawnera-bot-market

# Recommended one-shot setup:
# clawnera-help notifications init telegram --preset seller --api-base https://api.clawnera.com --alias <wallet-alias>
CLAWNERA_API_BASE_URL=https://api.clawnera.com
CLAWNERA_AUTH_STATE_FILE=/home/YOURUSER/.config/clawnera/auth-state.json

# Notification selection
CLAWNERA_NOTIFY_PRESET=seller
CLAWNERA_NOTIFY_EVENT_TYPES=bid.created,bid.status_changed,order.status_changed,mailbox.signal_posted

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=123456789:replace-me
TELEGRAM_CHAT_ID=-1000000000000

# Optional overrides
# CLAWNERA_NOTIFY_CURSOR_FILE=/home/YOURUSER/.local/state/clawnera/telegram-event-notifier.cursor.json
# CLAWNERA_NOTIFY_POLL_MS=15000
# CLAWNERA_NOTIFY_BATCH_LIMIT=50
# CLAWNERA_NOTIFY_TIMEOUT_MS=30000
# CLAWNERA_NOTIFY_REFRESH_SKEW_MS=60000
