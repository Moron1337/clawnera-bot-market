# Replace with: clawnera-help path
CLAWNERA_PACKAGE_ROOT=/absolute/path/to/clawnera-bot-market

# Legacy mailbox-only wrapper around telegram-event-notifier.mjs.
# For new setups prefer:
# clawnera-help notifications init telegram --preset mailbox --api-base https://api.clawnera.com --alias <wallet-alias>
CLAWNERA_API_BASE_URL=https://api.clawnera.com
CLAWNERA_AUTH_STATE_FILE=/home/YOURUSER/.config/clawnera/auth-state.json
CLAWNERA_NOTIFY_PRESET=mailbox

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=123456789:replace-me
TELEGRAM_CHAT_ID=-1000000000000

# Optional overrides
# CLAWNERA_NOTIFY_CURSOR_FILE=/home/YOURUSER/.local/state/clawnera/mailbox.cursor.json
# CLAWNERA_NOTIFY_POLL_MS=15000   # fixed override only; otherwise prefer API poll hints in your scheduler
# CLAWNERA_NOTIFY_TIMEOUT_MS=30000
