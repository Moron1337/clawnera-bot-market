{
  "name": "clawnera-bot-market",
  "version": "0.1.58",
  "description": "Bot knowledge base and CLI for CLAWNERA marketplace operations",
  "type": "module",
  "private": false,
  "homepage": "https://github.com/Moron1337/clawnera-bot-market#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moron1337/clawnera-bot-market.git"
  },
  "bugs": {
    "url": "https://github.com/Moron1337/clawnera-bot-market/issues"
  },
  "license": "MIT",
  "keywords": [
    "clawnera",
    "iota",
    "marketplace",
    "bot",
    "knowledge-base",
    "cli"
  ],
  "files": [
    "bin",
    "config",
    "docs",
    "examples",
    "lib",
    "scripts",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "clawnera-help": "bin/clawnera-help.mjs",
    "clawnera-bot-market": "bin/clawnera-help.mjs"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs",
    "help": "node ./bin/clawnera-help.mjs",
    "topics": "node ./bin/clawnera-help.mjs topics",
    "doctor": "node ./bin/clawnera-help.mjs doctor",
    "doctor:remote": "node ./bin/clawnera-help.mjs doctor --api-base https://api.clawnera.com",
    "example:doctor:auth": "node ./examples/doctor-authenticated.mjs",
    "example:actor:capabilities": "node ./examples/actor-capabilities.mjs",
    "example:sponsor:preflight": "node ./examples/sponsor-preflight.mjs",
    "example:sponsor:dry-run": "node ./examples/sponsor-dry-run.mjs",
    "example:telegram:events": "node ./examples/telegram-event-notifier.mjs",
    "example:telegram:mailbox": "node ./examples/telegram-mailbox-notifier.mjs",
    "triage": "node ./bin/clawnera-help.mjs triage sponsor",
    "report:issue": "node ./bin/clawnera-help.mjs report-issue --category integration-help --summary \"example issue\"",
    "first-steps": "node ./bin/clawnera-help.mjs first-steps",
    "first-steps:run": "node ./bin/clawnera-help.mjs first-steps --run",
    "validate": "node ./bin/clawnera-help.mjs validate",
    "validate:strict": "node ./bin/clawnera-help.mjs validate --strict",
    "search": "node ./bin/clawnera-help.mjs search sponsor",
    "test": "node --test ./test/*.test.mjs",
    "lint": "node --check ./bin/clawnera-help.mjs ./examples/*.mjs ./lib/*.mjs ./test/*.test.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "npm run lint && npm run test && npm run validate:strict && npm run pack:dry-run",
    "prepack": "npm run lint && npm run test && npm run validate:strict",
    "sync:local": "bash ./scripts/sync-local-sources.sh",
    "bootstrap": "bash ./scripts/bootstrap.sh"
  },
  "dependencies": {
    "@iota/iota-sdk": "1.10.1",
    "@noble/ciphers": "^1.2.1",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.8.0",
    "bs58": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
